{
  "id": "anthropic.multi_turn",
  "provider": "anthropic",
  "feature": "multi_turn",
  "description": "Multiple user/assistant messages",
  "request": {
    "method": "POST",
    "url": "https://api.anthropic.com/v1/messages",
    "headers": {
      "x-api-key": "$ANTHROPIC_API_KEY",
      "anthropic-version": "2023-06-01",
      "content-type": "application/json"
    },
    "body": {
      "model": "claude-sonnet-4-5",
      "messages": [
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "What is 2 + 2? Reply with one word."
            }
          ]
        },
        {
          "role": "assistant",
          "content": [
            {
              "type": "text",
              "text": "four"
            }
          ]
        },
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "Repeat your previous answer in uppercase."
            }
          ]
        }
      ],
      "max_tokens": 32,
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
