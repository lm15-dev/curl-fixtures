{
  "id": "anthropic.system_content_blocks",
  "provider": "anthropic",
  "feature": "system_content_blocks",
  "description": "System prompt as content blocks with cache_control",
  "request": {
    "method": "POST",
    "url": "https://api.anthropic.com/v1/messages",
    "headers": {
      "x-api-key": "$ANTHROPIC_API_KEY",
      "anthropic-version": "2023-06-01",
      "anthropic-beta": "prompt-caching-2024-07-31",
      "content-type": "application/json"
    },
    "body": {
      "model": "claude-sonnet-4-5",
      "messages": [
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "Reply with the single word: pong"
            }
          ]
        }
      ],
      "system": [
        {
          "type": "text",
          "text": "You are terse."
        },
        {
          "type": "text",
          "text": "Prefer one-word answers when possible.",
          "cache_control": {
            "type": "ephemeral"
          }
        }
      ],
      "max_tokens": 64,
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
