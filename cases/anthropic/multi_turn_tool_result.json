{
  "id": "anthropic.multi_turn_tool_result",
  "provider": "anthropic",
  "feature": "multi_turn_tool_result",
  "description": "Conversation with tool_use + tool_result blocks",
  "request": {
    "method": "POST",
    "url": "https://api.anthropic.com/v1/messages",
    "headers": {
      "x-api-key": "$ANTHROPIC_API_KEY",
      "anthropic-version": "2023-06-01",
      "content-type": "application/json"
    },
    "body": {
      "model": "claude-sonnet-4-5",
      "messages": [
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "What is 2 + 2? Use the calculator tool, then answer in one word."
            }
          ]
        },
        {
          "role": "assistant",
          "content": [
            {
              "type": "tool_use",
              "id": "toolu_calc_2_plus_2",
              "name": "calculator",
              "input": {
                "expression": "2 + 2"
              }
            }
          ]
        },
        {
          "role": "user",
          "content": [
            {
              "type": "tool_result",
              "tool_use_id": "toolu_calc_2_plus_2",
              "content": "4"
            }
          ]
        }
      ],
      "tools": [
        {
          "name": "calculator",
          "description": "Evaluate a basic arithmetic expression",
          "input_schema": {
            "type": "object",
            "properties": {
              "expression": {
                "type": "string"
              }
            },
            "required": ["expression"]
          }
        }
      ],
      "max_tokens": 128,
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
