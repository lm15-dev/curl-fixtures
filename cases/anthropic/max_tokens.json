{
  "id": "anthropic.max_tokens",
  "provider": "anthropic",
  "feature": "max_tokens",
  "description": "max_tokens is required for Anthropic, always present",
  "request": {
    "method": "POST",
    "url": "https://api.anthropic.com/v1/messages",
    "headers": {
      "x-api-key": "$ANTHROPIC_API_KEY",
      "anthropic-version": "2023-06-01",
      "content-type": "application/json"
    },
    "body": {
      "model": "claude-sonnet-4-5",
      "messages": [
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "Say hello."
            }
          ]
        }
      ],
      "max_tokens": 100,
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
