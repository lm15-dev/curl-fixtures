{
  "id": "anthropic.service_tier",
  "provider": "anthropic",
  "feature": "service_tier",
  "description": "service_tier selection",
  "request": {
    "method": "POST",
    "url": "https://api.anthropic.com/v1/messages",
    "headers": {
      "x-api-key": "$ANTHROPIC_API_KEY",
      "anthropic-version": "2023-06-01",
      "content-type": "application/json"
    },
    "body": {
      "model": "claude-sonnet-4-5",
      "messages": [
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "Reply with exactly: tiered"
            }
          ]
        }
      ],
      "max_tokens": 16,
      "service_tier": "standard_only",
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
