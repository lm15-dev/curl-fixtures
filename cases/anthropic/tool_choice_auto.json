{
  "id": "anthropic.tool_choice_auto",
  "provider": "anthropic",
  "feature": "tool_choice_auto",
  "description": "Automatic tool choice",
  "request": {
    "method": "POST",
    "url": "https://api.anthropic.com/v1/messages",
    "headers": {
      "x-api-key": "$ANTHROPIC_API_KEY",
      "anthropic-version": "2023-06-01",
      "content-type": "application/json"
    },
    "body": {
      "model": "claude-sonnet-4-5",
      "messages": [
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "What is the weather in Montreal?"
            }
          ]
        }
      ],
      "tools": [
        {
          "name": "get_weather",
          "description": "Get the current weather for a city",
          "input_schema": {
            "type": "object",
            "properties": {
              "city": { "type": "string" }
            },
            "required": ["city"]
          }
        }
      ],
      "tool_choice": { "type": "auto" },
      "max_tokens": 1024,
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
