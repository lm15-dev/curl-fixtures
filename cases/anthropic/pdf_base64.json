{
  "id": "anthropic.pdf_base64",
  "provider": "anthropic",
  "feature": "pdf_base64",
  "description": "PDF input via base64 document source",
  "request": {
    "method": "POST",
    "url": "https://api.anthropic.com/v1/messages",
    "headers": {
      "x-api-key": "$ANTHROPIC_API_KEY",
      "anthropic-version": "2023-06-01",
      "content-type": "application/json"
    },
    "body": {
      "model": "claude-sonnet-4-5",
      "messages": [
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "What are the two words in this PDF? Reply with only those two words."
            },
            {
              "type": "document",
              "source": {
                "type": "base64",
                "media_type": "application/pdf",
                "data": ""
              }
            }
          ]
        }
      ],
      "max_tokens": 512,
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
