{
  "id": "anthropic.web_search",
  "provider": "anthropic",
  "feature": "web_search",
  "description": "Web search via server-side web_search tool",
  "request": {
    "method": "POST",
    "url": "https://api.anthropic.com/v1/messages",
    "headers": {
      "x-api-key": "$ANTHROPIC_API_KEY",
      "anthropic-version": "2023-06-01",
      "content-type": "application/json"
    },
    "body": {
      "model": "claude-sonnet-4-5",
      "messages": [
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "What was one positive news story from today? Reply in one sentence."
            }
          ]
        }
      ],
      "tools": [
        {
          "type": "web_search_20250305",
          "name": "web_search"
        }
      ],
      "max_tokens": 1024,
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
