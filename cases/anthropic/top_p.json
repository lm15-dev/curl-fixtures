{
  "id": "anthropic.top_p",
  "provider": "anthropic",
  "feature": "top_p",
  "description": "top_p (nucleus sampling)",
  "request": {
    "method": "POST",
    "url": "https://api.anthropic.com/v1/messages",
    "headers": {
      "x-api-key": "$ANTHROPIC_API_KEY",
      "anthropic-version": "2023-06-01",
      "content-type": "application/json"
    },
    "body": {
      "model": "claude-sonnet-4-5",
      "messages": [
        {
          "role": "user",
          "content": [
            {
              "type": "text",
              "text": "Write one short slogan about science."
            }
          ]
        }
      ],
      "top_p": 0.8,
      "max_tokens": 256,
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
