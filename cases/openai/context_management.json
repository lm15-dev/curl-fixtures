{
  "id": "openai.context_management",
  "provider": "openai",
  "feature": "context_management",
  "description": "Context management / compaction configuration",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Reply with exactly: compacted"
            }
          ]
        }
      ],
      "context_management": [
        {
          "type": "compaction",
          "compact_threshold": 1000
        }
      ],
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
