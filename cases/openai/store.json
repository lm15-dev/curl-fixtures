{
  "id": "openai.store",
  "provider": "openai",
  "feature": "store",
  "description": "store: true/false for response storage",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Reply with exactly: stored"
            }
          ]
        }
      ],
      "store": false,
      "stream": false
    }
  },
  "expect": {
    "status": 200,
    "body_contains": [
      "\"store\": false"
    ]
  }
}
