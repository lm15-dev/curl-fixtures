{
  "id": "openai.prompt_cache_key",
  "provider": "openai",
  "feature": "prompt_cache_key",
  "description": "prompt_cache_key for caching",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Reply with exactly: cached"
            }
          ]
        }
      ],
      "prompt_cache_key": "fixture-openai-prompt-cache-key",
      "stream": false
    }
  },
  "expect": {
    "status": 200,
    "body_contains": [
      "\"prompt_cache_key\": \"fixture-openai-prompt-cache-key\""
    ]
  }
}
