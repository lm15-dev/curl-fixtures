{
  "id": "openai.reasoning",
  "provider": "openai",
  "feature": "reasoning",
  "description": "reasoning.effort parameter",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-5-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "What is 143 times 27? Reply with just the number."
            }
          ]
        }
      ],
      "reasoning": {
        "effort": "low"
      },
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
