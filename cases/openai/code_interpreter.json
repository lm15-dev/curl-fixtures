{
  "id": "openai.code_interpreter",
  "provider": "openai",
  "feature": "code_interpreter",
  "description": "Code interpreter tool",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-5.4",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Use Python in the code interpreter to compute the SHA256 hash of the exact string 'curl-fixtures-2026-04-13'. Reply with only the lowercase hex digest."
            }
          ]
        }
      ],
      "tools": [
        {
          "type": "code_interpreter",
          "container": {
            "type": "auto"
          }
        }
      ],
      "include": [
        "code_interpreter_call.outputs"
      ],
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
