{
  "id": "openai.image_url",
  "provider": "openai",
  "feature": "image_url",
  "description": "Image input via input_image.image_url using a data URL",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Describe this image in a few words."
            },
            {
              "type": "input_image",
              "image_url": "https://raw.githubusercontent.com/github/explore/main/topics/react/react.png",
              "detail": "low"
            }
          ]
        }
      ],
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
