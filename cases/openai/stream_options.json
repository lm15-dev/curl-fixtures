{
  "id": "openai.stream_options",
  "provider": "openai",
  "feature": "stream_options",
  "description": "stream_options (include_obfuscation)",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Reply with exactly: stream"
            }
          ]
        }
      ],
      "stream": true,
      "stream_options": {
        "include_obfuscation": false
      }
    }
  },
  "expect": {
    "status": 200
  }
}
