{
  "id": "openai.previous_response_id",
  "provider": "openai",
  "feature": "previous_response_id",
  "description": "Chain responses via previous_response_id",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "previous_response_id": "$AUTO_PREVIOUS_RESPONSE_ID",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Reply with exactly: done"
            }
          ]
        }
      ],
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
