{
  "id": "openai.web_search",
  "provider": "openai",
  "feature": "web_search",
  "description": "Web search tool",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-5.4",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "What was one positive news story from today? Reply in one sentence."
            }
          ]
        }
      ],
      "tools": [
        {
          "type": "web_search_preview",
          "search_context_size": "low"
        }
      ],
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
