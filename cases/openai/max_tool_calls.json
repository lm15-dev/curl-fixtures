{
  "id": "openai.max_tool_calls",
  "provider": "openai",
  "feature": "max_tool_calls",
  "description": "Limit built-in tool calls with max_tool_calls",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Use web search to verify which city the Eiffel Tower is in. Answer with just the city name."
            }
          ]
        }
      ],
      "tools": [
        {
          "type": "web_search_preview",
          "search_context_size": "low"
        }
      ],
      "max_tool_calls": 1,
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
