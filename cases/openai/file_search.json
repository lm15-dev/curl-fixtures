{
  "id": "openai.file_search",
  "provider": "openai",
  "feature": "file_search",
  "description": "File search / retrieval tool",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "What files do you find? Reply briefly."
            }
          ]
        }
      ],
      "tools": [
        {
          "type": "file_search",
          "vector_store_ids": ["$AUTO_VECTOR_STORE_ID"],
          "max_num_results": 1
        }
      ],
      "tool_choice": {
        "type": "file_search"
      },
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
