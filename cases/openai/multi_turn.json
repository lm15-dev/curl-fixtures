{
  "id": "openai.multi_turn",
  "provider": "openai",
  "feature": "multi_turn",
  "description": "Multiple user/assistant messages",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": "What is 2 + 2? Reply with one word."
        },
        {
          "role": "assistant",
          "content": "four"
        },
        {
          "role": "user",
          "content": "Repeat your previous answer in uppercase."
        }
      ],
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
