{
  "id": "openai.structured_output",
  "provider": "openai",
  "feature": "structured_output",
  "description": "Structured output via text.format json_schema",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Return a cookie recipe as JSON."
            }
          ]
        }
      ],
      "text": {
        "format": {
          "type": "json_schema",
          "name": "recipe",
          "strict": true,
          "schema": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "ingredients": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["name", "ingredients"],
            "additionalProperties": false
          }
        }
      },
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
