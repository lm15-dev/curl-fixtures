{
  "id": "openai.background",
  "provider": "openai",
  "feature": "background",
  "description": "background: true for async processing",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Reply with exactly: bg"
            }
          ]
        }
      ],
      "background": true,
      "stream": true
    }
  },
  "expect": {
    "status": 200
  }
}
