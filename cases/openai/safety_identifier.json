{
  "id": "openai.safety_identifier",
  "provider": "openai",
  "feature": "safety_identifier",
  "description": "safety_identifier for content filtering",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Reply with exactly: safeid"
            }
          ]
        }
      ],
      "safety_identifier": "fixture-openai-safety-id-1",
      "stream": false
    }
  },
  "expect": {
    "status": 200,
    "body_contains": [
      "\"safety_identifier\": \"fixture-openai-safety-id-1\""
    ]
  }
}
