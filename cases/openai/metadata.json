{
  "id": "openai.metadata",
  "provider": "openai",
  "feature": "metadata",
  "description": "Request metadata",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Reply with exactly: meta"
            }
          ]
        }
      ],
      "metadata": {
        "fixture": "openai.metadata"
      },
      "stream": false
    }
  },
  "expect": {
    "status": 200,
    "body_contains": [
      "\"fixture\": \"openai.metadata\""
    ]
  }
}
