{
  "id": "openai.temperature",
  "provider": "openai",
  "feature": "temperature",
  "description": "Temperature and max_output_tokens",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Write a haiku."
            }
          ]
        }
      ],
      "temperature": 0.7,
      "max_output_tokens": 50,
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
