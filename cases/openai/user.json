{
  "id": "openai.user",
  "provider": "openai",
  "feature": "user",
  "description": "user identifier for abuse tracking",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "Reply with exactly: user"
            }
          ]
        }
      ],
      "user": "fixture-openai-user",
      "stream": false
    }
  },
  "expect": {
    "status": 200,
    "body_contains": [
      "\"user\": \"fixture-openai-user\""
    ]
  }
}
