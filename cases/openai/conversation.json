{
  "id": "openai.conversation",
  "provider": "openai",
  "feature": "conversation",
  "description": "Conversation object for multi-turn",
  "request": {
    "method": "POST",
    "url": "https://api.openai.com/v1/responses",
    "headers": {
      "Authorization": "Bearer $OPENAI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "model": "gpt-4.1-mini",
      "input": [
        {
          "role": "user",
          "content": [
            {
              "type": "input_text",
              "text": "What codeword did I ask you to remember? Reply with one word."
            }
          ]
        }
      ],
      "conversation": {
        "id": "$AUTO_CONVERSATION_ID"
      },
      "stream": false
    }
  },
  "expect": {
    "status": 200
  }
}
