{
  "id": "gemini.stop_sequences",
  "provider": "gemini",
  "feature": "stop_sequences",
  "description": "generationConfig.stopSequences",
  "request": {
    "method": "POST",
    "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
    "headers": {
      "x-goog-api-key": "$GEMINI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "contents": [
        {
          "role": "user",
          "parts": [
            {
              "text": "Repeat exactly: alpha STOP beta"
            }
          ]
        }
      ],
      "generationConfig": {
        "stopSequences": [
          "STOP"
        ]
      }
    }
  },
  "expect": {
    "status": 200
  }
}
