{
  "id": "gemini.pdf_inline",
  "provider": "gemini",
  "feature": "pdf_inline",
  "description": "PDF input via inlineData base64",
  "request": {
    "method": "POST",
    "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
    "headers": {
      "x-goog-api-key": "$GEMINI_API_KEY",
      "Content-Type": "application/json"
    },
    "body": {
      "contents": [
        {
          "role": "user",
          "parts": [
            {
              "text": "What are the two words in this PDF? Reply with only those two words."
            },
            {
              "inlineData": {
                "mimeType": "application/pdf",
                "data": ""
              }
            }
          ]
        }
      ]
    }
  },
  "expect": {
    "status": 200
  }
}
